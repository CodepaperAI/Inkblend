# Resend email config for the /api/quote handler.
# Copy to .env.local and fill in real values. .env* is gitignored.

# Get from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Inbox that receives quote/contact form submissions
QUOTE_TO_EMAIL=inkblend8@gmail.com

# FROM address shown in the inbox.
# Before verifying a domain in Resend, use: Ink Blend <onboarding@resend.dev>
# After verifying inkblend.ca (or whatever the real domain is) in Resend, use: Ink Blend <hello@inkblend.ca>
QUOTE_FROM_EMAIL=Ink Blend <onboarding@resend.dev>
